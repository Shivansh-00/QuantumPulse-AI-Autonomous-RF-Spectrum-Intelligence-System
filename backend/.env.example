# QuantumPulse AI - Backend Configuration

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://quantumpulse:quantumpulse@db:5432/quantumpulse
SYNC_DATABASE_URL=postgresql://quantumpulse:quantumpulse@db:5432/quantumpulse

# Redis
REDIS_URL=redis://redis:6379/0

# RF Simulation Defaults
DEFAULT_SAMPLE_RATE=10000
DEFAULT_DURATION=1.0
DEFAULT_NUM_SIGNALS=5

# AI Model
MODEL_PATH=models/saved/congestion_predictor.pt
SEQUENCE_LENGTH=50
PREDICTION_HORIZON=10

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:3001"]
